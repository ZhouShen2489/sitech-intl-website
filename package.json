{
  "name": "sitech-intl-website",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "company-site",
    "opera-site",
    "telecom-site",
    "shared-assets"
  ],
  "scripts": {
    "dev": "npm run check:images && next dev",
    "dev:company": "pnpm --dir company-site run dev -- -p 3004",
    "dev:opera": "pnpm --dir opera-site run dev -- -p 3003",
    "dev:telecom": "pnpm --dir telecom-site run dev -- -p 3005",
    "dev:sites": "pnpm run dev:company & pnpm run dev:opera & pnpm run dev:telecom",
    "build": "next build",
    "build:pages": "node scripts/build-pages.mjs",
    "check:images": "node scripts/check-images-dev.mjs",
    "ocr:sitech-manual": "swift scripts/ocr-sitech-manual.swift",
    "start": "next start",
    "build:company": "npm --workspace @sitech/company-site run build",
    "build:opera": "npm --workspace @sitech/opera-site run build",
    "build:telecom": "npm --workspace @sitech/telecom-site run build",
    "build:sites": "npm run build:company && npm run build:opera && npm run build:telecom"
  },
  "dependencies": {
    "google-auth-library": "9.15.1",
    "next": "15.5.15",
    "nodemailer": "8.0.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@types/nodemailer": "7.0.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  }
}
