# Copy this file to `.env.local` for local development.
# None of the secrets below should be committed to git.

# Where internal website inquiry emails should be delivered.
# In your case this should normally be:
# CONTACT_RECIPIENT=info@sitech-intl.com
# Multiple recipients are supported, separated by commas.
CONTACT_RECIPIENT=info@sitech-intl.com,zhous@sitech-intl.com

# Gmail sender account used by the backend to send:
# 1. internal lead notification emails
# 2. automatic confirmation emails to the visitor
#
# Recommended source:
# use the Google account that is allowed to send for your business mailbox,
# ideally the mailbox that should appear as the sender or a delegated sender.
GMAIL_SENDER=zhous@sitech-intl.com

# Google OAuth2 values used by Nodemailer.
# Recommended source:
# Google Cloud Console -> APIs & Services -> Credentials
# Create OAuth client credentials for the Gmail-sending account flow,
# then obtain a refresh token for that account.
# A helper script is available at `scripts/get-gmail-refresh-token.mjs`.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REFRESH_TOKEN=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/oauth2callback

# HubSpot Private App token.
# Recommended source:
# HubSpot -> Settings -> Integrations -> Private Apps
# Create a private app with the needed CRM/Form scopes.
HUBSPOT_ACCESS_TOKEN=your-hubspot-private-app-token

# If you want submissions to go through a HubSpot Form first,
# create a form in HubSpot and put its portal ID + form ID here.
# Recommended source:
# HubSpot form settings / embed details / forms API references.
HUBSPOT_FORM_PORTAL_ID=
HUBSPOT_FORM_ID=

# These are the internal names of the HubSpot fields/properties
# used to store the inquiry category and inquiry detail text.
# If you create custom HubSpot fields, use their internal names here.
HUBSPOT_FIELD_INTERESTED_IN=website_interested_in
HUBSPOT_FIELD_MESSAGE=website_inquiry_details

# Optional but recommended custom HubSpot fields so each website inquiry
# is clearly marked as coming from the website and preserves page language.
HUBSPOT_FIELD_SOURCE=website_lead_source
HUBSPOT_FIELD_LOCALE=website_inquiry_locale
